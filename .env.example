# ═══════════════════════════════════════════════════════════════════════════════
# Portfolio Insight – Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in all values marked [SENSITIVE] – never commit .env to version control
# 3. Values marked [NON-SENSITIVE] are safe defaults you can override if needed
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (choose ONE) ─────────────────────────────────────────────────

# [SENSITIVE] OpenAI API key – get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# [SENSITIVE] Anthropic API key – get from https://console.anthropic.com/
# Leave blank if using OpenAI
ANTHROPIC_API_KEY=

# [NON-SENSITIVE] LLM provider to use: "openai" or "anthropic"
LLM_PROVIDER=openai

# [NON-SENSITIVE] Model name to use
# OpenAI options:    gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic options: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
# Local / Ollama:     deepseek-r1:7b, llama3.2, mistral, etc.
LLM_MODEL=gpt-4o-mini

# [NON-SENSITIVE] Local OpenAI-compatible server base URL.
# When set, OPENAI_API_KEY is not required and LLM_PROVIDER is ignored.
# Ollama:    LLM_BASE_URL=http://localhost:11434/v1
# LM Studio: LLM_BASE_URL=http://localhost:1234/v1
# Docker (host network): use http://host.docker.internal:11434/v1
# Leave blank to use the official OpenAI/Anthropic cloud endpoints.
LLM_BASE_URL=

# [NON-SENSITIVE] Input context window size in tokens.
#   Local 4-bit quantized models:  4096
#   Local 8-bit models:            8192
#   GPT-4o-mini / GPT-4o:         32768
#   Claude 3.5 Sonnet:           200000
LLM_CONTEXT_WINDOW=4096

# ── Zerodha Kite MCP ──────────────────────────────────────────────────────────

# [NON-SENSITIVE] Hosted Kite MCP endpoint (no API key needed for hosted version)
KITE_MCP_URL=https://mcp.kite.trade/mcp

# [SENSITIVE] Required ONLY if self-hosting kite-mcp-server locally
# Leave blank when using the hosted version at mcp.kite.trade
KITE_API_KEY=
KITE_API_SECRET=

# [NON-SENSITIVE] MCP connection timeout in seconds
KITE_MCP_TIMEOUT=30

# ── News ─────────────────────────────────────────────────────────────────────

# [SENSITIVE] NewsAPI.org key — https://newsapi.org/register
# Free tier: 100 requests/day. Leave blank to rely only on the free GNews source.
NEWSAPI_KEY=

# [NON-SENSITIVE] Number of news articles to fetch per stock (max 5 recommended)
NEWS_ARTICLES_PER_STOCK=5

# [NON-SENSITIVE] News lookback period in days (free NewsAPI tier max: 30)
NEWS_LOOKBACK_DAYS=7

# [NON-SENSITIVE] How long to cache NewsAPI responses in seconds (default: 1 hour)
# Prevents exhausting the 100 req/day free quota on repeated runs.
NEWSAPI_CACHE_TTL_SECONDS=3600

# ── Gold API (COMEX Commodity Prices) ────────────────────────────────────────

# [SENSITIVE] gold-api.com API key – https://gold-api.com/
# Provides live COMEX prices for Gold (XAU), Silver (XAG), Platinum (XPT),
# Palladium (XPD), Copper (HG). Used for pre-market signal detection.
GOLD_API_KEY=your_gold_api_key_here

# ── Application Settings ──────────────────────────────────────────────────────

# [NON-SENSITIVE] Output directory for generated portfolio reports
OUTPUT_DIR=./output

# [NON-SENSITIVE] Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# [NON-SENSITIVE] Maximum number of holdings to analyze in one run (0 = all)
MAX_HOLDINGS_PER_RUN=0

# [NON-SENSITIVE] Request delay in seconds between scraping calls (be polite)
SCRAPE_DELAY_SECONDS=2

# [NON-SENSITIVE] How long to cache COMEX gold-api.com responses in seconds (default: 1 hour)
COMEX_CACHE_TTL_SECONDS=3600

# ── ClickHouse (historical data importer) ────────────────────────────────────
# Used by: docker compose run mosaic import

# [NON-SENSITIVE] ClickHouse server host
# When running with Docker Compose this is automatically set to "clickhouse"
CLICKHOUSE_HOST=localhost

# [NON-SENSITIVE] ClickHouse HTTP port
CLICKHOUSE_PORT=8123

# [NON-SENSITIVE] ClickHouse database (created automatically on first import)
CLICKHOUSE_DATABASE=market_data

# [NON-SENSITIVE] ClickHouse username (default install uses "default")
CLICKHOUSE_USER=default

# [SENSITIVE] ClickHouse password (leave blank for default no-auth setup)
CLICKHOUSE_PASSWORD=

# ── Docker notes ─────────────────────────────────────────────────────────────
# When running via Docker:
#   - OUTPUT_DIR is overridden to /app/output (mounted as ./output on host)
#   - NO_BROWSER=1 is set automatically (HTML is still generated in ./output/)
#   - For local LLM, use http://host.docker.internal:<port>/v1 as LLM_BASE_URL
#   - CLICKHOUSE_HOST is overridden to "clickhouse" (the compose service name)
