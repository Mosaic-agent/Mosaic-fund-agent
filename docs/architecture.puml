@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 12
skinparam roundcorner 6
skinparam componentStyle rectangle
skinparam packageBorderColor #AAAAAA
skinparam packageBackgroundColor #FAFAFA
skinparam componentBorderColor #888888
skinparam componentBackgroundColor #FFFFFF
skinparam databaseBorderColor #888888
skinparam databaseBackgroundColor #F5F5F5
skinparam arrowColor #555555
skinparam noteBorderColor #CCCCCC
skinparam noteBackgroundColor #FFFDE7

title Portfolio Insight — Agent Orchestration

actor "User" as User

package "CLI  (src/main.py  ·  typer)" #EBF5FB {
  component "analyze [--demo  --max N  --quiet]\nask \"question\"\nconfig" as CLI
}

package "PortfolioAgent  (portfolio_agent.py)" #FFFDE7 {

  package "analyze  →  Sequential Pipeline  (run_full_analysis)" #E8F5E9 {
    component "① Fetch Holdings\nKiteMCPClient  →  Zerodha Kite MCP\nOAuth browser login  ·  demo: built-in sample data" as S1
    component "② Enrich Each Holding  (asset_analyzer.py)\nruns once per holding in portfolio" as S2
    component "③ LLM Scoring  (summarization.py)\nrisk 1–10  ·  sentiment −1 to +1  ·  5 insights  ·  summary" as S3
    component "④ Portfolio Aggregation  (portfolio_analyzer.py)\nsector allocation  ·  health score  ·  rebalancing" as S4
    component "⑤ COMEX Pre-Market Signals  (comex_fetcher.py)\nXAU  XAG  HG  XPT  XPD  —  live spot vs prev close" as S5
    component "⑥ Format & Save  (output.py)\nRich terminal panels  ·  JSON  ./output/*.json" as S6

    S1 -down-> S2
    S2 -down-> S3
    S3 -down-> S4
    S4 -down-> S5
    S5 -down-> S6
  }

  package "ask  →  LangGraph ReAct Loop" #FFF3E0 {
    component "LLM reasons over registered tools\nreason → act → observe  until done" as ReAct
  }

}

package "Enrichment Tools  (Step ②)" #F1F8E9 {
  component "yahoo_finance.py\nprice · P/E · sector · 30-day momentum" as YF
  component "news_search.py\nNewsAPI.org — last 7 days" as NS
  component "earnings_scraper.py\nScreener.in · Yahoo Finance fallback" as ES
  component "inav_fetcher.py  [ETF only]\nNSE live iNAV — every 15 seconds" as IV
  component "historic_inav.py  [ETF only]\nAMFI 30-day NAV history via MFAPI.in" as HI
}

package "External Services" #F8F8F8 {
  database "Zerodha Kite MCP\nhttps://mcp.kite.trade/mcp" as KiteSvc
  database "Yahoo Finance\n.NS  /  .BO  /  GC=F  SI=F  HG=F…" as YFSvc
  database "NewsAPI.org" as NewsSvc
  database "Screener.in" as ScrnSvc
  database "NSE API\n+  MFAPI.in  (AMFI)" as NSESvc
  database "gold-api.com\nx-access-token auth" as GoldSvc
  database "OpenAI  /  Anthropic\nGPT-4o-mini  ·  Claude Haiku" as LLMSvc
}

User -down-> CLI
CLI -down-> S1 : analyze
CLI -down-> ReAct : ask

S2 -right-> YF
S2 -right-> NS
S2 -right-> ES
S2 -right-> IV
S2 -right-> HI

S1 ..> KiteSvc : OAuth + REST
YF ..> YFSvc
NS ..> NewsSvc
ES ..> ScrnSvc
IV ..> NSESvc
HI ..> NSESvc
S3 ..> LLMSvc
S5 ..> GoldSvc : live spot prices
S5 ..> YFSvc : futures — prev close

note right of S3
  demo mode:
  rule-based scoring,
  no LLM key required
end note

note right of S5
  all API response fields validated:
  symbol whitelist · positive-float price
  string length cap · regex injection guard
end note

@enduml
